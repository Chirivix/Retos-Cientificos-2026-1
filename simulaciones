        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# --- Parámetros del experimento ---\n",
        "g = 9.81       # Gravedad (m/s^2)\n",
        "m = 0.05       # Masa colgante (kg)\n",
        "M = 0.1        # Masa puntual sobre la plataforma (kg)\n",
        "R = 0.15       # Distancia de la masa puntual al centro (m)\n",
        "r = 0.02       # Radio de la polea/eje (m)\n",
        "I_base = 0.01  # Inercia de la plataforma sola (kg*m^2)\n",
        "\n",
        "# --- Cálculos iniciales ---\n",
        "I_total = I_base + (M * R**2)\n",
        "alpha = (m * g * r) / (I_total + m * r**2)\n",
        "a = alpha * r\n",
        "\n",
        "# --- Simulación temporal ---\n",
        "t_final = 5.0  # segundos\n",
        "dt = 0.01      # paso del tiempo\n",
        "tiempo = np.arange(0, t_final, dt)\n",
        "\n",
        "# Ecuaciones de movimiento\n",
        "theta = 0.5 * alpha * tiempo**2  # Posición angular\n",
        "y_masa = 0.5 * a * tiempo**2     # Caída de la masa colgante\n",
        "\n",
        "# --- Visualización de resultados ---\n",
        "plt.figure(figsize=(10, 5))\n",
        "\n",
        "plt.subplot(1, 2, 1)\n",
        "plt.plot(tiempo, theta, color='blue')\n",
        "plt.title('Posición Angular de la Plataforma')\n",
        "plt.xlabel('Tiempo (s)')\n",
        "plt.ylabel('Ángulo (rad)')\n",
        "\n",
        "plt.subplot(1, 2, 2)\n",
        "plt.plot(tiempo, y_masa, color='red')\n",
        "plt.title('Caída de la Masa Colgante')\n",
        "plt.xlabel('Tiempo (s)')\n",
        "plt.ylabel('Distancia (m)')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    }
